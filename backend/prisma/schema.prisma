// Prisma Schema for Document Management System (DMS)
// Database: MySQL

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================
// USER MANAGEMENT
// ============================================

model User {
  id                  Int        @id @default(autoincrement())
  email               String     @unique
  password            String
  firstName           String?
  lastName            String?
  phone               String?
  department          String?
  position            String?
  employeeId          String?    @unique
  dateJoined          DateTime   @default(now())
  profileImage        String?
  status              UserStatus @default(ACTIVE)
  lastLogin           DateTime?
  failedAttempts      Int        @default(0)
  lockedUntil         DateTime?
  // Two-Factor Authentication
  twoFactorEnabled    Boolean    @default(false)
  twoFactorMethod     String?    @default("email")
  twoFactorSecret     String?
  twoFactorTempSecret String?
  twoFactorCode       String?
  twoFactorCodeExpiry DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Relations
  roles                     UserRole[]
  sessions                  UserSession[]
  trustedDevices            TrustedDevice[]
  preferences               UserPreference?
  createdDocuments          Document[]                 @relation("DocumentCreator")
  ownedDocuments            Document[]                 @relation("DocumentOwner")
  reviewingDocuments        Document[]                 @relation("DocumentReviewer")
  firstApprovingDocuments   Document[]                 @relation("DocumentFirstApprover")
  secondApprovingDocuments  Document[]                 @relation("DocumentSecondApprover")
  createdFolders            Folder[]                   @relation("FolderCreator")
  approvalHistory           ApprovalHistory[]
  comments                  DocumentComment[]
  notifications             Notification[]
  auditLogs                 AuditLog[]
  versionUploads            DocumentVersion[]          @relation("VersionUploader")
  generatedReports          GeneratedReport[]
  backups                   Backup[]
  createdSupersedeRequests  SupersedeObsoleteRequest[] @relation("RequestCreator")
  reviewedSupersedeRequests SupersedeObsoleteRequest[] @relation("RequestReviewer")
  approvedSupersedeRequests SupersedeObsoleteRequest[] @relation("RequestApprover")
  rejectedSupersedeRequests SupersedeObsoleteRequest[] @relation("RequestRejector")
  createdVersionRequests    VersionRequest[]           @relation("VersionRequestCreator")
  reviewedVersionRequests   VersionRequest[]           @relation("VersionRequestReviewer")
  approvedVersionRequests   VersionRequest[]           @relation("VersionRequestApprover")
  rejectedVersionRequests   VersionRequest[]           @relation("VersionRequestRejector")
  documentAssignments       DocumentAssignment[]
  createdTemplateRequests   TemplateRequest[]          @relation("TemplateRequestCreator")
  resolvedTemplateRequests  TemplateRequest[]          @relation("TemplateRequestResolver")
  folderPermissions         FolderPermission[]
  managedProjects           Project[]                  @relation("ProjectManager")
  createdProjects           Project[]                  @relation("ProjectCreator")
  assignedProjectItems      ProjectIterationDocumentItem[] @relation("ProjectItemAssignee")
  linkedProjectDocuments    ProjectDocumentLink[]      @relation("ProjectDocumentLinkedBy")
  epcTrackingUpdates        DocumentEpcRegistryRecord[] @relation("EpcTrackingUpdatedBy")
  documentConfidentialAccessEntries DocumentConfidentialAccess[]
  requirementConfidentialAccessEntries ProjectCategoryDocumentRequirementConfidentialAccess[]
  projectSetupRequirementDefaultAccessEntries ProjectSetupDocumentRequirementDefaultConfidentialAccess[]
  projectSetupRequirementOverrideAccessEntries ProjectSetupDocumentRequirementOverrideConfidentialAccess[]
  createdProjectChangeRequests ProjectChangeRequest[] @relation("ProjectChangeRequestCreator")
  expiryWatchers            DocumentExpiryWatcher[]

  @@index([email])
  @@index([employeeId])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  LOCKED
}

enum TemplateRequestType {
  NEW
  UPDATE
}

enum TemplateRequestStatus {
  PENDING
  RESOLVED
  REJECTED
}

enum RfidTrackingStatus {
  REGISTER
  CHECK_IN
  CHECK_OUT
  ARCHIVE
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  displayName String
  description String?
  permissions Json? // Store permissions as JSON
  isSystem    Boolean  @default(false) // System roles cannot be deleted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users             UserRole[]
  workflowSteps     WorkflowStep[]
  folderPermissions FolderPermission[]
  documentConfidentialAccessEntries DocumentConfidentialAccess[]
  requirementConfidentialAccessEntries ProjectCategoryDocumentRequirementConfidentialAccess[]
  projectSetupRequirementDefaultAccessEntries ProjectSetupDocumentRequirementDefaultConfidentialAccess[]
  projectSetupRequirementOverrideAccessEntries ProjectSetupDocumentRequirementOverrideConfidentialAccess[]
}

model UserRole {
  id         Int      @id @default(autoincrement())
  userId     Int
  roleId     Int
  assignedAt DateTime @default(now())
  assignedBy Int?

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model UserSession {
  id           Int      @id @default(autoincrement())
  userId       Int
  token        String   @unique @db.VarChar(512)
  refreshToken String?  @unique @db.VarChar(512)
  device       String?
  ipAddress    String?
  userAgent    String?  @db.Text
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id         Int       @id @default(autoincrement())
  userId     Int
  tokenHash  String    @unique @db.VarChar(128)
  userAgent  String?   @db.Text
  ipAddress  String?
  expiresAt  DateTime
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model UserPreference {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  language      String   @default("en")
  timezone      String   @default("Asia/Kuala_Lumpur")
  dateFormat    String   @default("DD/MM/YYYY")
  timeFormat    String   @default("24h")
  itemsPerPage  Int      @default(15)
  defaultView   String   @default("list")
  emailDigest   String   @default("daily")
  notifications Json? // Email and in-app notification preferences
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================
// DOCUMENT MANAGEMENT
// ============================================

model DocumentType {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  prefix      String   @unique // e.g., "DOC", "MoM", "PP"
  description String?
  isActive    Boolean  @default(true)
  requiresExpiryTracking Boolean @default(false)
  allowRenewal Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  documents        Document[]
  templates        Template[]
  templateRequests TemplateRequest[]
  workflows        Workflow[]
  codeRegistries   CodeRegistry[]
  projectRequirements ProjectCategoryDocumentRequirement[]
  projectItems        ProjectIterationDocumentItem[]
  projectSetupDefaultRequirements ProjectSetupDocumentRequirementDefault[]
  projectSetupOverrideRequirements ProjectSetupDocumentRequirementOverride[]
}

model ProjectCategory {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique // e.g., "INT", "EXT", "CLIENT"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  documents      Document[]
  codeRegistries CodeRegistry[]
  projects             Project[]
  categoryStages       ProjectCategoryStage[]
  documentRequirements ProjectCategoryDocumentRequirement[]
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique // e.g., "IT", "HR", "FIN"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Folder {
  id                 Int      @id @default(autoincrement())
  name               String
  parentId           Int?
  createdById        Int
  accessMode         String   @default("PUBLIC")
  inheritPermissions Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relations
  parent      Folder?            @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children    Folder[]           @relation("FolderHierarchy")
  documents   Document[]
  createdBy   User               @relation("FolderCreator", fields: [createdById], references: [id])
  permissions FolderPermission[]

  @@index([parentId])
  @@index([createdById])
}

model FolderPermission {
  id          Int      @id @default(autoincrement())
  folderId    Int
  userId      Int?
  roleId      Int?
  canView     Boolean  @default(false)
  canCreate   Boolean  @default(false)
  canEdit     Boolean  @default(false)
  canDelete   Boolean  @default(false)
  canDownload Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folder Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role?  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([folderId, userId])
  @@unique([folderId, roleId])
  @@index([folderId])
  @@index([userId])
  @@index([roleId])
}

model Document {
  id                Int           @id @default(autoincrement())
  fileCode          String        // e.g., DOC-2025-001
  isClientDocument  Boolean       @default(false)
  isConfidential    Boolean       @default(false)
  title             String
  description       String?       @db.Text
  documentTypeId    Int
  projectCategoryId Int?
  folderId          Int? // Folder assignment
  status            DocStatus     @default(DRAFT)
  stage             WorkflowStage @default(DRAFT)
  version           String        @default("1.0")

  // User references
  createdById      Int
  ownerId          Int // Current document owner
  submittedById    Int?
  reviewerId       Int? // Assigned reviewer
  reviewedById     Int? // User who completed the review
  firstApproverId  Int? // First level approver
  secondApproverId Int? // Second level approver
  publishedById    Int? // User who published the document
  acknowledgedById Int?

  // Supersede/Obsolete
  supersededById Int? // Document that supersedes this one
  obsoleteReason String?   @db.Text
  obsoleteDate   DateTime?

  // Document date (for file code generation)
  dateOfDocument DateTime? // User-specified document date (used in file code)

  // Timestamps
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  submittedAt      DateTime?
  reviewedAt       DateTime?
  firstApprovedAt  DateTime?
  secondApprovedAt DateTime?
  acknowledgedAt   DateTime?
  publishedAt      DateTime?

  // Relations
  documentType           DocumentType               @relation(fields: [documentTypeId], references: [id])
  projectCategory        ProjectCategory?           @relation(fields: [projectCategoryId], references: [id], onDelete: SetNull)
  folder                 Folder?                    @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdBy              User                       @relation("DocumentCreator", fields: [createdById], references: [id])
  owner                  User                       @relation("DocumentOwner", fields: [ownerId], references: [id])
  reviewer               User?                      @relation("DocumentReviewer", fields: [reviewerId], references: [id])
  firstApprover          User?                      @relation("DocumentFirstApprover", fields: [firstApproverId], references: [id])
  secondApprover         User?                      @relation("DocumentSecondApprover", fields: [secondApproverId], references: [id])
  versions               DocumentVersion[]
  approvalHistory        ApprovalHistory[]
  comments               DocumentComment[]
  metadata               DocumentMetadata[]
  supersededBy           Document?                  @relation("DocumentSupersede", fields: [supersededById], references: [id], onDelete: SetNull, onUpdate: NoAction)
  supersedes             Document[]                 @relation("DocumentSupersede")
  supersedeRequests      SupersedeObsoleteRequest[] @relation("DocumentToObsolete")
  supersedingForRequests SupersedeObsoleteRequest[] @relation("SupersedingDocument")
  versionRequests        VersionRequest[]           @relation("VersionRequestSource")
  newVersionRequests     VersionRequest[]           @relation("VersionRequestNew")
  assignments            DocumentAssignment[]
  epcRegistryRecords     DocumentEpcRegistryRecord[]
  projectLinks           ProjectDocumentLink[]
  confidentialAccess     DocumentConfidentialAccess[]
  expiryProfile          DocumentExpiryProfile?
  expiryRenewalHistory   DocumentExpiryRenewalHistory[]

  @@unique([fileCode, projectCategoryId])
  @@index([fileCode])
  @@index([status])
  @@index([stage])
  @@index([documentTypeId])
  @@index([projectCategoryId])
  @@index([folderId])
  @@index([createdById])
  @@index([ownerId])
  @@index([createdAt])
}

enum AccessSubjectType {
  USER
  ROLE
}

model DocumentConfidentialAccess {
  id          Int               @id @default(autoincrement())
  documentId  Int
  subjectType AccessSubjectType
  userId      Int?
  roleId      Int?
  canView     Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  role     Role?    @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId])
  @@unique([documentId, roleId])
  @@index([documentId])
  @@index([userId])
  @@index([roleId])
  @@index([subjectType])
}

enum DocStatus {
  DRAFT
  PENDING_REVIEW
  IN_REVIEW
  PENDING_FIRST_APPROVAL
  IN_FIRST_APPROVAL
  PENDING_SECOND_APPROVAL
  IN_SECOND_APPROVAL
  READY_TO_PUBLISH
  PENDING_ACKNOWLEDGMENT
  ACKNOWLEDGED
  APPROVED
  PUBLISHED
  REJECTED
  RETURNED
  SUPERSEDED
  OBSOLETE
  ARCHIVED

  // Legacy statuses (deprecated but kept for backward compatibility)
  PENDING_APPROVAL
  IN_APPROVAL
}

enum WorkflowStage {
  DRAFT
  REVIEW
  FIRST_APPROVAL
  SECOND_APPROVAL
  READY_TO_PUBLISH
  ACKNOWLEDGMENT
  PUBLISHED
  SUPERSEDED
  OBSOLETE

  // Legacy stage (deprecated but kept for backward compatibility)
  APPROVAL
}

enum ExpiryStatus {
  ACTIVE
  EXPIRING_SOON
  EXPIRING_TODAY
  EXPIRED
}

enum RenewalStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

model Project {
  id                Int           @id @default(autoincrement())
  code              String        @unique
  name              String
  description       String?       @db.Text
  clientName        String?
  clientPic         String?
  teamMembers       String?       @db.Text
  startDate         DateTime?
  plannedCompletionDate DateTime?
  actualCompletionDate  DateTime?
  scope             String?       @db.Text
  objective         String?       @db.Text
  deliverables      String?       @db.Text
  projectCategoryId Int
  managerId         Int
  createdById       Int
  status            ProjectStatus @default(ACTIVE)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  projectCategory ProjectCategory  @relation(fields: [projectCategoryId], references: [id], onDelete: Restrict)
  manager         User             @relation("ProjectManager", fields: [managerId], references: [id], onDelete: Restrict)
  createdBy       User             @relation("ProjectCreator", fields: [createdById], references: [id], onDelete: Restrict)
  iterations      ProjectIteration[]
  setupStageOverrides ProjectSetupStageOverride[]
  setupRequirementOverrides ProjectSetupDocumentRequirementOverride[]
  changeRequests  ProjectChangeRequest[]

  @@index([projectCategoryId])
  @@index([managerId])
  @@index([createdById])
  @@index([status])
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  CLOSED
  ARCHIVED
}

model ProjectIteration {
  id             Int      @id @default(autoincrement())
  projectId      Int
  iterationNo    Int
  name           String?
  currentStageId Int?
  startedAt      DateTime?
  endedAt        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project                 Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  currentStage            ProjectStageDefinition? @relation("IterationCurrentStage", fields: [currentStageId], references: [id], onDelete: SetNull)
  items                   ProjectIterationDocumentItem[]
  links                   ProjectDocumentLink[]
  changeRequests          ProjectChangeRequest[]

  @@unique([projectId, iterationNo])
  @@index([projectId])
  @@index([currentStageId])
  @@index([isActive])
}

model ProjectChangeRequest {
  id                 Int      @id @default(autoincrement())
  projectId          Int
  projectIterationId Int?
  changeId           String
  phaseRef           String?
  description        String   @db.Text
  impact             String?  @db.Text
  authorizedBy       String?
  complianceSignOff  String?
  dateApproved       DateTime?
  createdById        Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  iteration ProjectIteration? @relation(fields: [projectIterationId], references: [id], onDelete: SetNull)
  createdBy User             @relation("ProjectChangeRequestCreator", fields: [createdById], references: [id], onDelete: Restrict)

  @@unique([projectId, changeId])
  @@index([projectId])
  @@index([projectIterationId])
  @@index([createdById])
  @@index([createdAt])
}

model ProjectStageDefinition {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  name      String
  sortOrder Int
  isSystem  Boolean  @default(true)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryStages      ProjectCategoryStage[]
  currentForIterations ProjectIteration[] @relation("IterationCurrentStage")
  requirements        ProjectCategoryDocumentRequirement[]
  setupStageDefaults  ProjectSetupStageDefault[]
  setupStageOverrides ProjectSetupStageOverride[]
  setupDefaultRequirements ProjectSetupDocumentRequirementDefault[]
  setupOverrideRequirements ProjectSetupDocumentRequirementOverride[]
  items               ProjectIterationDocumentItem[]
  links               ProjectDocumentLink[]

  @@index([sortOrder])
  @@index([isActive])
}

model ProjectCategoryStage {
  id                Int      @id @default(autoincrement())
  projectCategoryId Int
  stageId           Int
  displayName       String?
  sortOrder         Int?
  isEnabled         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  projectCategory ProjectCategory        @relation(fields: [projectCategoryId], references: [id], onDelete: Cascade)
  stage           ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([projectCategoryId, stageId])
  @@index([projectCategoryId])
  @@index([stageId])
  @@index([isEnabled])
}

model ProjectCategoryDocumentRequirement {
  id                    Int      @id @default(autoincrement())
  projectCategoryId     Int
  stageId               Int
  documentTypeId        Int
  isRequired            Boolean  @default(true)
  isConfidentialDefault Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  projectCategory ProjectCategory        @relation(fields: [projectCategoryId], references: [id], onDelete: Cascade)
  stage           ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade)
  documentType    DocumentType           @relation(fields: [documentTypeId], references: [id], onDelete: Cascade)
  confidentialAccess ProjectCategoryDocumentRequirementConfidentialAccess[]

  @@unique([projectCategoryId, stageId, documentTypeId], map: "PCDR_pcid_sid_dtid_key")
  @@index([projectCategoryId])
  @@index([stageId])
  @@index([documentTypeId])
  @@index([isRequired])
}

model ProjectCategoryDocumentRequirementConfidentialAccess {
  id            Int               @id @default(autoincrement())
  requirementId Int
  subjectType   AccessSubjectType
  userId        Int?
  roleId        Int?
  canView       Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requirement ProjectCategoryDocumentRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)
  user        User?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role?               @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([requirementId, userId], map: "PCDRCA_reqid_userid_key")
  @@unique([requirementId, roleId], map: "PCDRCA_reqid_roleid_key")
  @@index([requirementId], map: "PCDRCA_reqid_idx")
  @@index([userId], map: "PCDRCA_userid_idx")
  @@index([roleId], map: "PCDRCA_roleid_idx")
  @@index([subjectType], map: "PCDRCA_subjectType_idx")
}

model ProjectSetupStageDefault {
  id          Int      @id @default(autoincrement())
  stageId     Int
  displayName String?
  sortOrder   Int?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stage ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade, map: "pssd_stage_fkey")

  @@unique([stageId])
  @@index([stageId])
  @@index([isEnabled])
}

model ProjectSetupStageOverride {
  id          Int      @id @default(autoincrement())
  projectId   Int
  stageId     Int
  displayName String?
  sortOrder   Int?
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project                @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "psso_project_fkey")
  stage   ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade, map: "psso_stage_fkey")

  @@unique([projectId, stageId])
  @@index([projectId])
  @@index([stageId])
  @@index([isEnabled])
}

model ProjectSetupDocumentRequirementDefault {
  id                    Int      @id @default(autoincrement())
  stageId               Int
  documentTypeId        Int
  isRequired            Boolean  @default(true)
  isConfidentialDefault Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  stage        ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade, map: "psdrd_stage_fkey")
  documentType DocumentType           @relation(fields: [documentTypeId], references: [id], onDelete: Cascade, map: "psdrd_doctype_fkey")
  confidentialAccess ProjectSetupDocumentRequirementDefaultConfidentialAccess[]

  @@unique([stageId, documentTypeId], map: "PSDRD_sid_dtid_key")
  @@index([stageId])
  @@index([documentTypeId])
  @@index([isRequired])
}

model ProjectSetupDocumentRequirementOverride {
  id                    Int      @id @default(autoincrement())
  projectId             Int
  stageId               Int
  documentTypeId        Int
  isRequired            Boolean  @default(true)
  isConfidentialDefault Boolean  @default(false)
  isExcluded            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade, map: "psdro_project_fkey")
  stage       ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Cascade, map: "psdro_stage_fkey")
  documentType DocumentType          @relation(fields: [documentTypeId], references: [id], onDelete: Cascade, map: "psdro_doctype_fkey")
  confidentialAccess ProjectSetupDocumentRequirementOverrideConfidentialAccess[]

  @@unique([projectId, stageId, documentTypeId], map: "PSDRO_pid_sid_dtid_key")
  @@index([projectId])
  @@index([stageId])
  @@index([documentTypeId])
  @@index([isRequired])
  @@index([isExcluded])
}

model ProjectSetupDocumentRequirementDefaultConfidentialAccess {
  id            Int               @id @default(autoincrement())
  requirementId Int
  subjectType   AccessSubjectType
  userId        Int?
  roleId        Int?
  canView       Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requirement ProjectSetupDocumentRequirementDefault @relation(fields: [requirementId], references: [id], onDelete: Cascade, map: "psdrdca_req_fkey")
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade, map: "psdrdca_user_fkey")
  role        Role?                @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "psdrdca_role_fkey")

  @@unique([requirementId, userId], map: "PSDRDCA_reqid_userid_key")
  @@unique([requirementId, roleId], map: "PSDRDCA_reqid_roleid_key")
  @@index([requirementId], map: "PSDRDCA_reqid_idx")
  @@index([userId], map: "PSDRDCA_userid_idx")
  @@index([roleId], map: "PSDRDCA_roleid_idx")
  @@index([subjectType], map: "PSDRDCA_subjectType_idx")
}

model ProjectSetupDocumentRequirementOverrideConfidentialAccess {
  id            Int               @id @default(autoincrement())
  requirementId Int
  subjectType   AccessSubjectType
  userId        Int?
  roleId        Int?
  canView       Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  requirement ProjectSetupDocumentRequirementOverride @relation(fields: [requirementId], references: [id], onDelete: Cascade, map: "psdroca_req_fkey")
  user        User?                @relation(fields: [userId], references: [id], onDelete: Cascade, map: "psdroca_user_fkey")
  role        Role?                @relation(fields: [roleId], references: [id], onDelete: Cascade, map: "psdroca_role_fkey")

  @@unique([requirementId, userId], map: "PSDROCA_reqid_userid_key")
  @@unique([requirementId, roleId], map: "PSDROCA_reqid_roleid_key")
  @@index([requirementId], map: "PSDROCA_reqid_idx")
  @@index([userId], map: "PSDROCA_userid_idx")
  @@index([roleId], map: "PSDROCA_roleid_idx")
  @@index([subjectType], map: "PSDROCA_subjectType_idx")
}

enum ProjectItemStatus {
  PENDING
  COMPLETE
  WAIVED
}

model ProjectIterationDocumentItem {
  id                 Int              @id @default(autoincrement())
  projectIterationId Int
  stageId            Int
  documentTypeId     Int
  status             ProjectItemStatus @default(PENDING)
  dueDate            DateTime?
  assignedToId       Int?
  completedAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  iteration   ProjectIteration      @relation(fields: [projectIterationId], references: [id], onDelete: Cascade)
  stage       ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Restrict)
  documentType DocumentType          @relation(fields: [documentTypeId], references: [id], onDelete: Restrict)
  assignedTo  User?                  @relation("ProjectItemAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  links       ProjectDocumentLink[]

  @@unique([projectIterationId, stageId, documentTypeId], map: "PIDI_piid_sid_dtid_key")
  @@index([projectIterationId])
  @@index([stageId])
  @@index([documentTypeId])
  @@index([status])
  @@index([assignedToId])
}

model ProjectDocumentLink {
  id                 Int      @id @default(autoincrement())
  projectIterationId Int
  stageId            Int
  itemId             Int?
  documentId         Int
  linkedById         Int
  linkedAt           DateTime @default(now())

  iteration ProjectIteration       @relation(fields: [projectIterationId], references: [id], onDelete: Cascade)
  stage     ProjectStageDefinition @relation(fields: [stageId], references: [id], onDelete: Restrict)
  item      ProjectIterationDocumentItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  document  Document               @relation(fields: [documentId], references: [id], onDelete: Cascade)
  linkedBy  User                   @relation("ProjectDocumentLinkedBy", fields: [linkedById], references: [id], onDelete: Restrict)

  @@unique([projectIterationId, documentId])
  @@index([projectIterationId])
  @@index([stageId])
  @@index([itemId])
  @@index([documentId])
  @@index([linkedById])
}

model DocumentVersion {
  id           Int      @id @default(autoincrement())
  documentId   Int
  version      String // e.g., "1.0", "1.1", "2.0"
  filePath     String
  fileName     String
  mimeType     String
  fileSize     Int // in bytes
  uploadedById Int
  isPublished  Boolean  @default(false)
  isEncrypted  Boolean  @default(false) // Whether file is AES-256 encrypted
  uploadedAt   DateTime @default(now())

  // Relations
  document          Document                  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  uploadedBy        User                      @relation("VersionUploader", fields: [uploadedById], references: [id])
  epcRegistryRecord DocumentEpcRegistryRecord?
  expiryRenewalHistory DocumentExpiryRenewalHistory[]

  @@index([documentId])
  @@index([version])
}

model DocumentExpiryProfile {
  id                   Int           @id @default(autoincrement())
  documentId           Int           @unique
  trackingEnabled      Boolean       @default(true)
  startDate            DateTime?
  expiryDate           DateTime?
  expiryStatus         ExpiryStatus  @default(ACTIVE)
  renewalStatus        RenewalStatus @default(NOT_STARTED)
  expiringSoonDays     Int?
  reminder1Days        Int?
  reminder2Days        Int?
  reminder3Days        Int?
  reminder4Days        Int?
  lastReminder1SentAt  DateTime?
  lastReminder2SentAt  DateTime?
  lastReminder3SentAt  DateTime?
  lastReminder4SentAt  DateTime?
  remarks              String?       @db.Text
  companySnapshot      String?
  departmentSnapshot   String?
  folderSnapshotName   String?
  currentVersionSnapshot String?
  trackingDisabledAt   DateTime?
  trackingDisabledBy   Int?
  trackingDisabledReason String?     @db.Text
  createdBy            Int?
  updatedBy            Int?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  renewalHistory DocumentExpiryRenewalHistory[]
  watchers DocumentExpiryWatcher[]

  @@index([expiryStatus])
  @@index([renewalStatus])
  @@index([trackingEnabled])
  @@index([expiryDate])
}

model DocumentExpiryRenewalHistory {
  id                  Int           @id @default(autoincrement())
  documentId          Int
  expiryProfileId     Int
  documentVersionId   Int?
  fromVersion         String?
  toVersion           String?
  previousExpiryDate  DateTime?
  newExpiryDate       DateTime?
  renewalStatusBefore RenewalStatus?
  renewalStatusAfter  RenewalStatus?
  remarks             String?       @db.Text
  renewedBy           Int?
  renewedAt           DateTime      @default(now())

  document        Document              @relation(fields: [documentId], references: [id], onDelete: Cascade)
  expiryProfile   DocumentExpiryProfile @relation(fields: [expiryProfileId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion?      @relation(fields: [documentVersionId], references: [id], onDelete: SetNull)

  @@index([documentId])
  @@index([expiryProfileId])
  @@index([renewedAt])
}

model DocumentExpiryWatcher {
  id              Int      @id @default(autoincrement())
  expiryProfileId Int
  userId          Int
  createdById     Int?
  createdAt       DateTime @default(now())

  expiryProfile DocumentExpiryProfile @relation(fields: [expiryProfileId], references: [id], onDelete: Cascade)
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([expiryProfileId, userId], map: "DEW_profile_user_key")
  @@index([expiryProfileId])
  @@index([userId])
}

model DocumentEpcRegistryRecord {
  id                 Int      @id @default(autoincrement())
  documentId         Int
  documentVersionId  Int      @unique
  fileCode           String
  fileName           String
  epcScheme          String   @default("SGTIN-96")
  epcHex             String   @unique
  filter             Int
  companyPrefixDigits Int
  companyPrefix      String
  itemReference      String
  serial             String
  tagUri             String
  pureIdentityUri    String
  generatedAt        DateTime @default(now())
  trackingStatus     RfidTrackingStatus @default(REGISTER)
  trackingUpdatedAt  DateTime @default(now())
  trackingUpdatedById Int?
  createdAt          DateTime @default(now())

  document        Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentVersion DocumentVersion @relation(fields: [documentVersionId], references: [id], onDelete: Cascade)
  trackingUpdatedBy User? @relation("EpcTrackingUpdatedBy", fields: [trackingUpdatedById], references: [id], onDelete: SetNull)

  @@index([generatedAt])
  @@index([fileCode])
  @@index([documentId])
  @@index([trackingStatus])
}

model DocumentMetadata {
  id         Int      @id @default(autoincrement())
  documentId Int
  key        String
  value      String   @db.Text
  createdAt  DateTime @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, key])
  @@index([documentId])
}

model DocumentComment {
  id          Int         @id @default(autoincrement())
  documentId  Int
  userId      Int
  comment     String      @db.Text
  commentType CommentType @default(GENERAL)
  createdAt   DateTime    @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
}

enum CommentType {
  GENERAL
  REVIEW
  APPROVAL
  REJECTION
  AMENDMENT
}

model DocumentAssignment {
  id             Int            @id @default(autoincrement())
  documentId     Int
  userId         Int
  assignmentType AssignmentType
  assignedById   Int?
  createdAt      DateTime       @default(now())
  expiresAt      DateTime? // Optional: auto-cleanup after workflow completion
  lastReminderSentAt DateTime?

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([documentId, userId, assignmentType])
  @@index([documentId])
  @@index([userId])
  @@index([assignmentType])
}

enum AssignmentType {
  REVIEW
  FIRST_APPROVAL
  SECOND_APPROVAL
  ACKNOWLEDGMENT
}

// ============================================
// VERSION REQUEST WORKFLOW
// ============================================

model VersionRequest {
  id                Int                  @id @default(autoincrement())
  documentId        Int // Original document to create new version for
  reasonForRevision String               @db.Text
  proposedChanges   String               @db.Text
  targetDate        DateTime?
  priority          String               @default("Normal") // Low, Normal, High, Critical
  remarks           String?              @db.Text
  filePath          String? // Optional draft file uploaded with request
  fileName          String?
  requestedById     Int
  status            RequestStatus        @default(PENDING_REVIEW)
  stage             RequestWorkflowStage @default(REVIEW)

  // Review stage
  reviewedById   Int?
  reviewedAt     DateTime?
  reviewComments String?   @db.Text

  // Approval stage
  approvedById     Int?
  approvedAt       DateTime?
  approvalComments String?   @db.Text

  // Rejection
  rejectedById    Int?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text

  // New document created after approval
  newDocumentId Int? // Links to the newly created document

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document    Document  @relation("VersionRequestSource", fields: [documentId], references: [id], onDelete: Cascade)
  newDocument Document? @relation("VersionRequestNew", fields: [newDocumentId], references: [id], onDelete: SetNull)
  requestedBy User      @relation("VersionRequestCreator", fields: [requestedById], references: [id])
  reviewedBy  User?     @relation("VersionRequestReviewer", fields: [reviewedById], references: [id])
  approvedBy  User?     @relation("VersionRequestApprover", fields: [approvedById], references: [id])
  rejectedBy  User?     @relation("VersionRequestRejector", fields: [rejectedById], references: [id])

  @@index([documentId])
  @@index([status])
  @@index([requestedById])
  @@index([createdAt])
}

// ============================================
// SUPERSEDE/OBSOLETE REQUEST WORKFLOW
// ============================================

model SupersedeObsoleteRequest {
  id               Int                  @id @default(autoincrement())
  documentId       Int // Document to be obsoleted/superseded
  actionType       SupersedeAction // SUPERSEDE or OBSOLETE
  supersedingDocId Int? // For SUPERSEDE only - the new document replacing this one
  reason           String               @db.Text
  requestedById    Int
  status           RequestStatus        @default(PENDING_REVIEW)
  stage            RequestWorkflowStage @default(REVIEW)

  // Review stage
  reviewedById   Int?
  reviewedAt     DateTime?
  reviewComments String?   @db.Text

  // Approval stage
  approvedById     Int?
  approvedAt       DateTime?
  approvalComments String?   @db.Text

  // Rejection
  rejectedById    Int?
  rejectedAt      DateTime?
  rejectionReason String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  document       Document  @relation("DocumentToObsolete", fields: [documentId], references: [id], onDelete: Cascade)
  supersedingDoc Document? @relation("SupersedingDocument", fields: [supersedingDocId], references: [id], onDelete: SetNull)
  requestedBy    User      @relation("RequestCreator", fields: [requestedById], references: [id])
  reviewedBy     User?     @relation("RequestReviewer", fields: [reviewedById], references: [id])
  approvedBy     User?     @relation("RequestApprover", fields: [approvedById], references: [id])
  rejectedBy     User?     @relation("RequestRejector", fields: [rejectedById], references: [id])

  @@index([documentId])
  @@index([status])
  @@index([requestedById])
  @@index([createdAt])
}

enum SupersedeAction {
  SUPERSEDE
  OBSOLETE
}

enum RequestStatus {
  PENDING_REVIEW
  IN_REVIEW
  PENDING_APPROVAL
  IN_APPROVAL
  APPROVED
  REJECTED
}

enum RequestWorkflowStage {
  REVIEW
  APPROVAL
  COMPLETED
}

// ============================================
// WORKFLOW MANAGEMENT
// ============================================

model Workflow {
  id             Int      @id @default(autoincrement())
  name           String
  description    String?  @db.Text
  documentTypeId Int      @unique
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  documentType DocumentType   @relation(fields: [documentTypeId], references: [id])
  steps        WorkflowStep[]

  @@index([documentTypeId])
}

model WorkflowStep {
  id         Int     @id @default(autoincrement())
  workflowId Int
  stepOrder  Int
  stepName   String // e.g., "Review", "Approval", "Acknowledgment"
  roleId     Int
  isRequired Boolean @default(true)
  dueInDays  Int? // Optional SLA in days

  // Relations
  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  role     Role     @relation(fields: [roleId], references: [id])

  @@unique([workflowId, stepOrder])
  @@index([workflowId])
  @@index([roleId])
}

model ApprovalHistory {
  id         Int            @id @default(autoincrement())
  documentId Int
  userId     Int
  action     ApprovalAction
  stage      WorkflowStage
  comments   String?        @db.Text
  createdAt  DateTime       @default(now())

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([documentId])
  @@index([userId])
  @@index([createdAt])
}

enum ApprovalAction {
  SUBMITTED
  REVIEWED
  FIRST_APPROVED
  SECOND_APPROVED
  READY_FOR_PUBLISH
  PUBLISHED
  REJECTED
  ACKNOWLEDGED
  RETURNED
  SUPERSEDED
  OBSOLETED
  ARCHIVED

  // Legacy action (deprecated)
  APPROVED
}

// ============================================
// TEMPLATE MANAGEMENT
// ============================================

model Template {
  id             Int      @id @default(autoincrement())
  documentTypeId Int
  templateName   String
  version        String
  filePath       String
  fileName       String
  uploadedBy     String
  uploadedOn     DateTime @default(now())
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relations
  documentType     DocumentType      @relation(fields: [documentTypeId], references: [id])
  templateRequests TemplateRequest[]

  @@index([documentTypeId])
}

model TemplateRequest {
  id               Int                   @id @default(autoincrement())
  requestType      TemplateRequestType
  status           TemplateRequestStatus @default(PENDING)
  documentTypeId   Int?
  documentTypeName String?
  templateId       Int?
  templateName     String?
  description      String?               @db.Text
  requestedById    Int
  resolvedById     Int?
  resolvedAt       DateTime?
  resolutionNote   String?               @db.Text
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  documentType DocumentType? @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)
  template     Template?     @relation(fields: [templateId], references: [id], onDelete: SetNull)
  requestedBy  User          @relation("TemplateRequestCreator", fields: [requestedById], references: [id])
  resolvedBy   User?         @relation("TemplateRequestResolver", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([documentTypeId])
  @@index([templateId])
  @@index([requestedById])
  @@index([createdAt])
}

// ============================================
// NOTIFICATION SYSTEM
// ============================================

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  type      NotificationType
  title     String
  message   String           @db.Text
  link      String?
  isRead    Boolean          @default(false)
  readAt    DateTime?
  createdAt DateTime         @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

enum NotificationType {
  DOCUMENT_ASSIGNED
  REVIEW_REQUIRED
  APPROVAL_REQUIRED
  ACKNOWLEDGMENT_REQUIRED
  STATUS_CHANGED
  DOCUMENT_APPROVED
  DOCUMENT_REJECTED
  DOCUMENT_RETURNED
  VERSION_UPDATE
  DOCUMENT_EXPIRING
  DOCUMENT_EXPIRED
  RENEWAL_IN_PROGRESS
  RENEWAL_COMPLETED
  SYSTEM_ALERT
}

// ============================================
// MASTER RECORDS & ARCHIVES
// ============================================

model CodeRegistry {
  id                 Int       @id @default(autoincrement())
  fileCode           String
  normalizedFileCode String
  documentTitle      String?
  documentDate       DateTime?
  registryStatus     String?
  revision           String?
  projectCategoryId  Int
  documentTypeId     Int?
  codeKey            String
  runningNumber      Int
  source             String    @default("SYSTEM")
  sourceRefId        Int?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  projectCategory ProjectCategory @relation(fields: [projectCategoryId], references: [id], onDelete: Restrict)
  documentType    DocumentType?   @relation(fields: [documentTypeId], references: [id], onDelete: SetNull)

  @@unique([fileCode, projectCategoryId])
  @@unique([projectCategoryId, codeKey, runningNumber])
  @@index([projectCategoryId, codeKey])
  @@index([fileCode])
}

model DocumentRegister {
  id             Int      @id @default(autoincrement())
  fileCode       String
  projectCategoryId Int?
  documentTitle  String
  documentType   String
  version        String
  registeredDate DateTime @default(now())
  owner          String
  department     String?
  status         String

  @@unique([fileCode, projectCategoryId])
  @@index([fileCode])
  @@index([registeredDate])
}

model VersionRegister {
  id              Int      @id @default(autoincrement())
  fileCode        String
  documentTitle   String
  previousVersion String
  newVersion      String
  versionDate     DateTime
  updatedBy       String
  changeSummary   String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([fileCode])
  @@index([versionDate])
}

model ObsoleteRegister {
  id            Int      @id @default(autoincrement())
  fileCode      String
  documentTitle String
  documentType  String
  obsoleteDate  DateTime
  reason        String   @db.Text
  replacedBy    String?
  lastOwner     String
  createdAt     DateTime @default(now())

  @@index([fileCode])
  @@index([obsoleteDate])
}

model ArchiveRegister {
  id             Int       @id @default(autoincrement())
  fileCode       String
  documentTitle  String
  version        String
  archivedDate   DateTime
  archivedBy     String
  currentVersion String
  retentionUntil DateTime?
  filePath       String
  createdAt      DateTime  @default(now())

  @@index([fileCode])
  @@index([archivedDate])
  @@index([retentionUntil])
}

// ============================================
// AUDIT LOGGING
// ============================================

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?
  action      String
  entity      String? // e.g., "Document", "User", "Template"
  entityId    Int?
  description String?  @db.Text
  metadata    Json?
  ipAddress   String?
  userAgent   String?  @db.Text
  isArchived  Boolean  @default(false) // For log archiving functionality
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@index([isArchived])
}

// ============================================
// REPORTS & ANALYTICS
// ============================================

model GeneratedReport {
  id            Int          @id @default(autoincrement())
  reportType    String // e.g., 'document-stats', 'user-activity'
  reportName    String
  filePath      String?
  format        String // PDF, EXCEL, CSV
  fileSize      Int? // in bytes
  status        ReportStatus @default(PENDING)
  config        Json? // Report configuration (date range, filters, etc)
  generatedById Int?
  createdAt     DateTime     @default(now())
  completedAt   DateTime?

  // Relations
  generatedBy User? @relation(fields: [generatedById], references: [id], onDelete: SetNull)

  @@index([generatedById])
  @@index([reportType])
  @@index([status])
  @@index([createdAt])
}

enum ReportStatus {
  PENDING
  GENERATING
  COMPLETED
  FAILED
}

// ============================================
// SYSTEM CONFIGURATION
// ============================================

model Configuration {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String   @db.LongText
  description String?
  updatedAt   DateTime @updatedAt
}

// ============================================
// BACKUP & RECOVERY
// ============================================

model Backup {
  id          Int      @id @default(autoincrement())
  name        String
  description String?  @db.Text
  fileName    String
  filePath    String
  size        BigInt   @default(0) // File size in bytes
  status      String   @default("completed") // completed, failed, in_progress
  createdById Int
  createdAt   DateTime @default(now())

  // Relations
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([createdById])
  @@index([createdAt])
}

// ============================================
// PUBLIC INQUIRIES
// ============================================

model Inquiry {
  id               Int       @id @default(autoincrement())
  name             String
  email            String
  subject          String    @default("General Inquiry")
  message          String    @db.Text
  organizationType String? // e.g., "Corporate", "Government", "SME", "Other"
  status           String    @default("new") // new, in_progress, resolved, closed
  submittedAt      DateTime  @default(now())
  respondedAt      DateTime?
  respondedBy      Int?
  notes            String?   @db.Text

  @@index([email])
  @@index([status])
  @@index([submittedAt])
}
